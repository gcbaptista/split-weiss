generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Group {
  id            String        @id @default(cuid())
  name          String
  currency      String        @default("EUR")
  emoji         String?
  passwordHash  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  members       GroupMember[]
  expenses      Expense[]
  settlements   Settlement[]
  auditLogs      ExpenseAuditLog[]
  groupAuditLogs GroupAuditLog[]
  deviceAccess   DeviceAccess[]
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  name     String
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  expenses        Expense[]
  expenseSplits   ExpenseSplit[]
  settlementsFrom Settlement[] @relation("SettlementFrom")
  settlementsTo   Settlement[] @relation("SettlementTo")
  deviceAccess  DeviceAccess[]
  auditLogs      ExpenseAuditLog[] @relation("AuditActor")
  groupAuditLogs GroupAuditLog[]  @relation("GroupAuditActor")

  @@unique([groupId, id])
  @@unique([groupId, name])
}

model Expense {
  id        String         @id @default(cuid())
  groupId   String
  payerId   String
  title     String
  amount    Decimal        @db.Decimal(12, 2)
  currency  String
  splitMode SplitMode
  date      DateTime
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer     GroupMember     @relation(fields: [payerId], references: [id])
  splits    ExpenseSplit[]
  auditLogs ExpenseAuditLog[]

  @@index([groupId, date])
}

enum SplitMode {
  PERCENTAGE
  LOCK
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  REVERTED
}

model ExpenseAuditLog {
  id                String      @id @default(cuid())
  originalExpenseId String
  expenseId         String?
  groupId           String
  actorId           String?
  action            AuditAction
  snapshot          Json
  createdAt         DateTime    @default(now())

  expense           Expense?    @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  group             Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actor             GroupMember? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([originalExpenseId])
  @@index([originalExpenseId, createdAt])
  @@index([groupId])
}

model ExpenseSplit {
  id         String   @id @default(cuid())
  expenseId  String
  userId     String
  amount     Decimal  @db.Decimal(12, 2)
  percentage Decimal? @db.Decimal(7, 2)
  isLocked   Boolean  @default(false)
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user       GroupMember @relation(fields: [userId], references: [id])
  @@unique([expenseId, userId])
}

model Settlement {
  id         String   @id @default(cuid())
  groupId    String
  fromUserId String
  toUserId   String
  amount     Decimal  @db.Decimal(12, 2)
  currency   String
  date       DateTime
  note       String?
  createdAt  DateTime @default(now())
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser   GroupMember @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser     GroupMember @relation("SettlementTo", fields: [toUserId], references: [id])

  @@index([groupId, date])
}

model GroupAuditLog {
  id        String       @id @default(cuid())
  groupId   String
  actorId   String?
  action    String       // e.g. MEMBER_ADDED, MEMBER_RENAMED, MEMBER_REMOVED, SETTLEMENT_CREATED, GROUP_UPDATED, GROUP_PASSWORD_CHANGED
  details   Json
  createdAt DateTime     @default(now())

  group Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actor GroupMember?  @relation("GroupAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([groupId, actorId])
}

model ExchangeRateCache {
  id           String   @id @default(cuid())
  baseCurrency String
  date         String
  rates        Json
  fetchedAt    DateTime @default(now())
  @@unique([baseCurrency, date])
}


model DeviceAccess {
  id          String       @id @default(cuid())
  groupId     String
  deviceToken String
  memberId    String?
  createdAt   DateTime     @default(now())
  lastUsedAt  DateTime     @updatedAt

  group  Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  member GroupMember?  @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@unique([groupId, deviceToken])
  @@index([deviceToken])
}